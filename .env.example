SECRET_KEY=mude-isto-para-uma-string-longa-e-aleatoria
DEBUG=True
ALLOWED_HOSTS=backend,localhost,127.0.0.1

# --- Base de dados (backend/core/settings.py) ---
# O Compose define DATABASE_URL; não precisas das linhas POSTGRES_* abaixo no Docker.
#
# PostgreSQL explícito (sem DATABASE_URL): define POSTGRES_HOST, ex. localhost
# POSTGRES_HOST=localhost
POSTGRES_USER=cltbot
POSTGRES_PASSWORD=cltbot
POSTGRES_DB=cltbot
# POSTGRES_PORT=5432

# Porta do API no teu computador (host)
BACKEND_PORT=8000

# --- Discord (bot) ---
DISCORD_TOKEN=
GUILD_ID=
VERIFIED_ROLE_ID=
VERIFICATION_CHANNEL_ID=

# Canal dedicado ao bolão (mensagem única; limpo ao iniciar novo jogo)
BOLAO_CHANNEL_ID=

# Cargo que pode iniciar/encerrar bolão (além de quem tem Administrador no servidor)
# ADMIN_ROLE_ID=1486856755052023983
# Opcional: cargos extra (legado), separados por vírgula
# BOLAO_ADMIN_ROLE_IDS=123456789,987654321

# Opcional
VERIFICATION_BULLET=🔹
